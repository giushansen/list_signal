<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.07] bg-ls-dark/85 backdrop-blur-xl">
  <div class="mx-auto max-w-[1200px] px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-display text-[21px] font-bold tracking-tight">
      <span class="flex h-[30px] w-[30px] items-center justify-center rounded-lg bg-accent text-[13px] font-extrabold text-white relative overflow-hidden">LS<span class="absolute inset-0 rounded-lg bg-gradient-to-br from-white/20 to-transparent"></span></span>
      ListSignal
    </a>
    <a href="/signup" class="rounded-lg bg-accent px-5 py-2 text-sm font-semibold text-white hover:bg-accent-hover transition-all">Start Free</a>
  </div>
</nav>

<main class="pt-[88px] pb-24" itemscope itemtype="https://schema.org/WebPage">
  <div class="mx-auto max-w-[960px] px-6">

    <%!-- Breadcrumb with Schema.org --%>
    <nav aria-label="breadcrumb" class="mb-6 text-sm text-white/40" itemscope itemtype="https://schema.org/BreadcrumbList">
      <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="/" itemprop="item" class="hover:text-white transition-colors"><span itemprop="name">Home</span></a>
        <meta itemprop="position" content="1" />
      </span>
      <span class="mx-2">/</span>
      <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="/apps" itemprop="item" class="hover:text-white transition-colors"><span itemprop="name">Stores</span></a>
        <meta itemprop="position" content="2" />
      </span>
      <span class="mx-2">/</span>
      <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="text-white/70">
        <span itemprop="name"><%= @store.domain %></span>
        <meta itemprop="position" content="3" />
      </span>
    </nav>

    <article itemscope itemtype="https://schema.org/Organization">
      <meta itemprop="url" content={"https://#{@store.domain}"} />

      <%!-- ═══ HEADER ═══ --%>
      <header class="mb-8">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
          <div>
            <h1 class="font-display text-[clamp(22px,4vw,36px)] font-bold tracking-tight leading-[1.15] mb-2" itemprop="name">
              <%= @store.domain %>
            </h1>
            <div class="flex flex-wrap items-center gap-3 text-[13px] text-white/50">
              <%= if Enum.any?(@store.tech, &(String.downcase(&1) |> String.contains?("shopify"))) do %>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-[#96BF48]/10 border border-[#96BF48]/20 px-3 py-1 text-[12px] font-semibold text-[#96BF48]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M15.34 3.8c-.07-.38-.39-.6-.65-.63-.26-.03-5.8-.44-5.8-.44s-3.84-3.83-4.24-4.23c-.4-.4-1.18-.28-1.48-.18-.01 0-.66.2-1.74.54L2.83 3.8H15.34z" transform="translate(4 6) scale(0.85)"/></svg>
                  Shopify Store
                </span>
              <% end %>
              <%= if @store.bgp_asn_country != "" do %>
                <span class="inline-flex items-center gap-1"><span class="text-base"><%= @store.country_flag %></span> <%= @store.bgp_asn_country %></span>
              <% end %>
              <%= if @store.http_language != "" do %>
                <span class="inline-flex items-center gap-1">
                  <%= if @store.language_flag != "" do %><span class="text-base"><%= @store.language_flag %></span><% end %>
                  <%= @store.http_language %>
                </span>
              <% end %>
              <span class="rounded bg-white/[0.06] px-2 py-0.5 text-[11px] font-mono text-white/40">.<%= String.downcase(@store.tld) %></span>
              <%= if @store.enriched_at != "" and @store.enriched_at != "just now" do %>
                <span>Last analyzed <%= String.slice(@store.enriched_at, 0, 10) %></span>
              <% else %>
                <span class="text-accent">⚡ Just scanned live</span>
              <% end %>
            </div>
          </div>
          <%= if @store.http_status do %>
            <div class={["rounded-full px-4 py-1.5 text-sm font-semibold border",
              if(@store.http_status == 200,
                do: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
                else: "bg-amber-500/10 text-amber-400 border-amber-500/20")]}>
              <%= if @store.http_status == 200, do: "🟢 Online", else: "⚠️ HTTP #{@store.http_status}" %>
            </div>
          <% end %>
        </div>
        <%= if @store.http_meta_description != "" do %>
          <p class="text-white/60 text-base leading-relaxed max-w-[720px]" itemprop="description"><%= @store.http_meta_description %></p>
        <% end %>
      </header>

      <%!-- ═══ QUICK STATS GRID ═══ --%>
      <% stats = [
        (@store.bgp_asn_country != "" && {"🏳️ Country", "#{@store.country_flag} #{@store.bgp_asn_country}", "Server location"}),
        (@store.http_language != "" && {"🗣️ Language", "#{@store.language_flag} #{@store.http_language}", "Primary site language"}),
        (@store.http_response_time && {"⚡ Site Speed", "#{@store.http_response_time}ms", response_time_label(@store.http_response_time)}),
        (@store.tranco_rank && {"📊 Traffic Rank", "##{@store.tranco_rank}", "Global popularity"}),
        (@store.bgp_asn_org != "" && {"🖥️ Hosting", @store.bgp_asn_org, "Infrastructure provider"}),
        (@store.rdap_registrar != "" && {"📋 Registrar", @store.rdap_registrar, "Domain registrar"}),
        (@store.domain_age && {"📆 Domain Age", @store.domain_age, "Since #{date_slice(@store.rdap_domain_created_at) || "registration"}"}),
        (@store.mail_provider && {"📧 Email Provider", @store.mail_provider, "Business email service"}),
        (@store.estimated_revenue != "" && {"💰 Est. Revenue", @store.estimated_revenue, "#{@store.estimated_employees} employees"}),
        (@store.business_model != "" && {"🏢 Business Model", @store.business_model, @store.industry})
      ] |> Enum.reject(&(!&1)) %>
      <%= if stats != [] do %>
        <section class="mb-8" aria-label="Key metrics">
          <h2 class="sr-only">Key Metrics for <%= @store.domain %></h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            <%= for {label, value, subtitle} <- stats do %>
              <div class="rounded-xl border border-white/[0.07] bg-white/[0.02] px-4 py-3 hover:border-white/[0.12] transition-colors">
                <div class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1"><%= label %></div>
                <div class="font-medium text-white text-sm truncate"><%= value %></div>
                <div class="text-[10px] text-white/25 mt-0.5 truncate"><%= subtitle %></div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%!-- ═══ TECH STACK ═══ --%>
      <% is_shopify = Enum.any?(@store.tech, &(String.downcase(&1) |> String.contains?("shopify")))
         display_tech = if is_shopify, do: Enum.reject(@store.tech, &(String.downcase(&1) |> String.contains?("shopify"))), else: @store.tech %>
      <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Technology stack">
        <h2 class="font-display text-lg font-semibold mb-1">🔧 Tech Stack (<%= length(display_tech) %> technologies)</h2>
        <p class="text-[13px] text-white/40 mb-4">Technologies detected on <%= @store.domain %></p>
        <%= if display_tech != [] do %>
          <div class="flex flex-wrap gap-2">
            <%= for tech <- display_tech do %>
              <a href={"/tech/#{tech |> String.downcase() |> String.replace(~r/[^a-z0-9]+/, "-") |> String.trim("-")}"}
                 class="inline-block rounded-lg border border-white/[0.07] bg-white/[0.03] px-3.5 py-1.5 text-sm text-white/70 hover:border-accent/30 hover:text-accent transition-all">
                <%= tech %>
              </a>
            <% end %>
          </div>
        <% else %>
          <p class="text-white/40 text-sm">No technologies detected.</p>
        <% end %>
      </section>

      <%!-- ═══ SHOPIFY APPS ═══ --%>
      <%= if @store.http_apps != [] do %>
        <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Shopify apps">
          <h2 class="font-display text-lg font-semibold mb-1">🛍️ Shopify Apps</h2>
          <p class="text-[13px] text-white/40 mb-4"><%= length(@store.http_apps) %> apps detected</p>
          <div class="flex flex-wrap gap-2">
            <%= for app <- @store.http_apps do %>
              <span class="inline-block rounded-lg border border-white/[0.07] bg-white/[0.03] px-3.5 py-1.5 text-sm text-white/70">
                <%= app %>
              </span>
            <% end %>
          </div>
        </section>
      <% end %>

      <%!-- ═══ DOMAIN REGISTRATION ═══ --%>
      <%= if @store.rdap_registrar != "" or @store.rdap_domain_created_at do %>
        <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Domain registration">
          <h2 class="font-display text-lg font-semibold mb-4">📋 Domain Registration</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
            <%= if @store.rdap_registrar != "" do %>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Registrar</div>
                <div class="text-white/80 text-xs"><%= @store.rdap_registrar %></div>
              </div>
            <% end %>
            <%= if @store.rdap_domain_created_at do %>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Registered</div>
                <div class="text-white/80"><%= String.slice(to_string(@store.rdap_domain_created_at), 0, 10) %></div>
                <%= if @store.domain_age do %>
                  <div class="text-[10px] text-accent/70 mt-0.5"><%= @store.domain_age %> ago</div>
                <% end %>
              </div>
            <% end %>
            <%= if @store.rdap_domain_expires_at do %>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Expires</div>
                <div class="text-white/80"><%= String.slice(to_string(@store.rdap_domain_expires_at), 0, 10) %></div>
              </div>
            <% end %>
            <%= if @store.dns_provider do %>
              <div>
                <div class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">DNS Provider</div>
                <div class="text-white/80 text-xs"><%= @store.dns_provider %></div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%!-- ═══ HOSTING & NETWORK ═══ --%>
      <%= if @store.bgp_asn_org != "" do %>
        <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Hosting and network">
          <h2 class="font-display text-lg font-semibold mb-4">🖥️ Hosting & Network</h2>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Provider</dt>
              <dd class="text-white/80 font-medium"><%= @store.bgp_asn_org %></dd>
            </div>
            <%= if @store.bgp_asn_country != "" do %>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Server Location</dt>
                <dd class="text-white/80"><%= @store.country_flag %> <%= @store.bgp_asn_country %></dd>
              </div>
            <% end %>
            <%= if @store.http_response_time do %>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Response Time</dt>
                <dd class={["font-mono text-xs font-semibold",
                  cond do
                    @store.http_response_time < 500 -> "text-emerald-400"
                    @store.http_response_time < 1500 -> "text-amber-400"
                    true -> "text-red-400"
                  end]}><%= @store.http_response_time %> ms</dd>
              </div>
            <% end %>
          </dl>
        </section>
      <% end %>

      <%!-- ═══ EMAIL & SECURITY ═══ --%>
      <%= if @store.mail_provider || @store.email_count > 0 || @store.has_spf || @store.has_dmarc do %>
        <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Email and security">
          <h2 class="font-display text-lg font-semibold mb-4">📧 Email & Security</h2>
          <div class="space-y-3 text-sm">
            <%= if @store.mail_provider do %>
              <div class="flex items-center gap-2">
                <span class="text-[10px] uppercase tracking-wider text-white/35 font-semibold w-32">Email Provider</span>
                <span class="text-white/80"><%= @store.mail_provider %></span>
              </div>
            <% end %>
            <div class="flex flex-wrap gap-2">
              <span class={["rounded-full px-3 py-1 text-xs font-semibold border",
                if(@store.has_spf, do: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20", else: "bg-red-500/10 text-red-400 border-red-500/20")]}>
                <%= if @store.has_spf, do: "✅ SPF Configured", else: "❌ No SPF" %>
              </span>
              <span class={["rounded-full px-3 py-1 text-xs font-semibold border",
                if(@store.has_dmarc, do: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20", else: "bg-red-500/10 text-red-400 border-red-500/20")]}>
                <%= if @store.has_dmarc, do: "✅ DMARC Configured", else: "❌ No DMARC" %>
              </span>
            </div>
            <%= if @store.email_count > 0 do %>
              <div class="flex items-center gap-2 text-white/50 mt-2">
                <span>🔒</span>
                <span><%= @store.email_count %> contact email<%= if @store.email_count > 1, do: "s" %> found</span>
                <a href="/signup" class="text-accent text-xs font-semibold hover:underline">Sign up to view</a>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%!-- ═══ REVENUE ESTIMATION ═══ --%>
      <%= if @store.estimated_revenue != "" do %>
        <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Revenue estimation">
          <h2 class="font-display text-lg font-semibold mb-4">💰 Revenue Estimation</h2>
          <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Estimated Revenue</dt>
              <dd class="text-white font-semibold text-lg"><%= @store.estimated_revenue %></dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Estimated Employees</dt>
              <dd class="text-white font-semibold text-lg"><%= @store.estimated_employees %></dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Confidence</dt>
              <dd class="text-white/80 font-semibold">
                <% conf = if @store.revenue_confidence, do: round(@store.revenue_confidence * 100), else: 0 %>
                <span class={"#{cond do
                  conf >= 70 -> "text-green-400"
                  conf >= 50 -> "text-yellow-400"
                  true -> "text-white/60"
                end}"}><%= conf %>%</span>
              </dd>
            </div>
          </dl>
          <%= if @store.revenue_evidence != "" do %>
            <details class="mt-4">
              <summary class="text-[11px] text-white/30 cursor-pointer hover:text-white/50">View scoring evidence</summary>
              <div class="mt-2 text-[11px] text-white/25 font-mono break-all leading-relaxed"><%= @store.revenue_evidence %></div>
            </details>
          <% end %>
        </section>
      <% end %>

      <%!-- ═══ RANKINGS & AUTHORITY ═══ --%>
      <%= if @store.tranco_rank || @store.majestic_rank do %>
        <section class="rounded-xl border border-white/[0.07] bg-[#111B33] p-6 mb-6" aria-label="Rankings and authority">
          <h2 class="font-display text-lg font-semibold mb-4">📊 Rankings & Authority</h2>
          <dl class="space-y-4 text-sm">
            <%= if @store.tranco_rank do %>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Traffic Rank</dt>
                <dd class="text-white/80 font-semibold">#<%= @store.tranco_rank %>
                  <span class="text-white/35 font-normal text-xs ml-1">
                    <%= cond do %>
                      <% @store.tranco_rank <= 1000 -> %>🏆 Top 1K
                      <% @store.tranco_rank <= 10_000 -> %>⭐ Top 10K
                      <% @store.tranco_rank <= 100_000 -> %>Top 100K
                      <% true -> %>among all websites
                    <% end %>
                  </span>
                </dd>
              </div>
            <% end %>
            <%= if @store.majestic_rank do %>
              <div>
                <dt class="text-[10px] uppercase tracking-wider text-white/35 font-semibold mb-1">Link Authority</dt>
                <dd class="text-white/80 font-semibold">#<%= @store.majestic_rank %>
                  <%= if @store.majestic_ref_subnets do %>
                    <span class="text-white/35 font-normal text-xs ml-1">with <%= @store.majestic_ref_subnets %> referring networks</span>
                  <% end %>
                </dd>
              </div>
            <% end %>
          </dl>
        </section>
      <% end %>

      <%!-- ═══ SAFETY BADGES (only show warnings) ═══ --%>
      <%= if @store.is_malware == "true" or @store.is_phishing == "true" or @store.is_disposable_email == "true" do %>
        <section class="mb-6 space-y-2" aria-label="Safety warnings">
          <%= if @store.is_malware == "true" do %>
            <div class="rounded-xl border border-red-500/20 bg-red-500/[0.05] px-5 py-3 text-sm text-red-400 font-semibold">🚨 Warning: This domain is flagged as malware</div>
          <% end %>
          <%= if @store.is_phishing == "true" do %>
            <div class="rounded-xl border border-red-500/20 bg-red-500/[0.05] px-5 py-3 text-sm text-red-400 font-semibold">🚨 Warning: This domain is flagged as phishing</div>
          <% end %>
          <%= if @store.is_disposable_email == "true" do %>
            <div class="rounded-xl border border-amber-500/20 bg-amber-500/[0.05] px-5 py-3 text-sm text-amber-400 font-semibold">⚠️ Uses disposable email domain</div>
          <% end %>
        </section>
      <% end %>

      <%!-- ═══ CONTACT DATA (gated) ═══ --%>
      <%= if @store.email_count > 0 or @store.subdomain_count > 0 do %>
        <section class="rounded-xl border border-white/[0.07] bg-white/[0.02] p-6 mb-6" aria-label="Contact data">
          <div class="flex flex-wrap gap-6 text-sm text-white/50">
            <%= if @store.email_count > 0 do %>
              <div class="flex items-center gap-2">
                <span>🔒</span>
                <span><%= @store.email_count %> email address<%= if @store.email_count > 1, do: "es" %> detected</span>
                <a href="/signup" class="text-accent font-semibold hover:underline text-xs">Sign up free to view</a>
              </div>
            <% end %>
            <%= if @store.subdomain_count > 0 do %>
              <div class="flex items-center gap-2">
                <span>🔒</span>
                <span><%= @store.subdomain_count %> subdomain<%= if @store.subdomain_count > 1, do: "s" %> detected</span>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%!-- ═══ FAQ — SEO + AI Crawling ═══ --%>
      <section class="mb-8" itemscope itemtype="https://schema.org/FAQPage" aria-label={"Frequently asked questions about #{@store.domain}"}>
        <h2 class="font-display text-xl font-semibold mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          <div class="rounded-xl border border-white/[0.07] bg-white/[0.02] p-5" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 itemprop="name" class="font-medium text-white mb-2">What platform does <%= @store.domain %> use?</h3>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text" class="text-sm text-white/60">
                <%= if Enum.any?(@store.tech, &(String.downcase(&1) |> String.contains?("shopify"))) do %>
                  <%= @store.domain %> runs on Shopify, one of the world's leading e-commerce platforms. ListSignal detected <%= length(@store.tech) %> technologies powering this store.
                <% else %>
                  ListSignal detected <%= length(@store.tech) %> technologies on <%= @store.domain %><%= if @store.tech_summary != "", do: ", including #{@store.tech_summary}", else: "" %>.
                <% end %>
              </p>
            </div>
          </div>
          <div class="rounded-xl border border-white/[0.07] bg-white/[0.02] p-5" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 itemprop="name" class="font-medium text-white mb-2">What technologies does <%= @store.domain %> use?</h3>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text" class="text-sm text-white/60">
                <%= @store.domain %> uses <%= length(@store.tech) %> detected technologies<%= if @store.tech_summary != "", do: ", including #{@store.tech_summary}", else: "" %>.
                <%= if @store.mail_provider, do: " Email is handled by #{@store.mail_provider}.", else: "" %>
              </p>
            </div>
          </div>
          <%= if @store.bgp_asn_org != "" do %>
            <div class="rounded-xl border border-white/[0.07] bg-white/[0.02] p-5" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <h3 itemprop="name" class="font-medium text-white mb-2">Who hosts <%= @store.domain %>?</h3>
              <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <p itemprop="text" class="text-sm text-white/60">
                  <%= @store.domain %> is hosted by <%= @store.bgp_asn_org %><%= if @store.bgp_asn_country != "", do: " in #{@store.bgp_asn_country}", else: "" %>.
                  <%= if @store.http_response_time, do: " Server response time is #{@store.http_response_time}ms.", else: "" %>
                </p>
              </div>
            </div>
          <% end %>
          <%= if @store.mail_provider do %>
            <div class="rounded-xl border border-white/[0.07] bg-white/[0.02] p-5" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
              <h3 itemprop="name" class="font-medium text-white mb-2">What email provider does <%= @store.domain %> use?</h3>
              <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                <p itemprop="text" class="text-sm text-white/60">
                  <%= @store.domain %> uses <%= @store.mail_provider %> for email, as detected from their mail exchange DNS records.
                </p>
              </div>
            </div>
          <% end %>
        </div>
      </section>

      <%!-- ═══ AI / LLM Summary Block (hidden visually, crawlable) ═══ --%>
      <div class="sr-only" aria-hidden="false" data-ai-summary="true">
        <h2>Summary of <%= @store.domain %></h2>
        <p>
          <%= @store.domain %> (<%= @store.title %>) is <%= if Enum.any?(@store.tech, &(String.downcase(&1) |> String.contains?("shopify"))), do: "a Shopify e-commerce store", else: "a website" %>
          <%= if @store.bgp_asn_country != "", do: "based in #{@store.bgp_asn_country}", else: "" %>
          <%= if @store.http_language != "", do: ", primary language: #{@store.http_language}", else: "" %>.
          Technologies: <%= @store.tech_summary %>.
          <%= if @store.mail_provider, do: "Email provider: #{@store.mail_provider}.", else: "" %>
          <%= if @store.bgp_asn_org != "", do: "Hosted by #{@store.bgp_asn_org}.", else: "" %>
          <%= if @store.rdap_registrar != "", do: "Registered via #{@store.rdap_registrar}.", else: "" %>
          <%= if @store.domain_age, do: "Domain age: #{@store.domain_age}.", else: "" %>
          <%= if @store.tranco_rank, do: "Traffic rank: ##{@store.tranco_rank}.", else: "" %>
        </p>
      </div>

      <div class="text-center py-8 border-t border-white/[0.07]">
        <p class="text-white/40 text-sm mb-4">Explore more Shopify store intelligence</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/" class="inline-flex items-center gap-2 rounded-xl bg-accent px-7 py-3.5 font-display text-sm font-semibold text-white hover:bg-accent-hover hover:-translate-y-0.5 transition-all">
            Search more stores
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h10M10 5l5 5-5 5"/></svg>
          </a>
          <a href="/apps" class="inline-flex items-center gap-2 rounded-xl border border-white/[0.1] px-6 py-3.5 font-display text-sm font-semibold text-white/60 hover:text-white hover:border-white/20 transition-all">
            Browse directory
          </a>
        </div>
      </div>

    </article>
  </div>
</main>

<footer class="border-t border-white/[0.07] py-8 text-center text-[13px] text-white/35">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-3">
      <a href="/features" class="text-white/50 hover:text-white transition-colors mx-4">Features</a>
      <a href="/pricing" class="text-white/50 hover:text-white transition-colors mx-4">Pricing</a>
      <a href="/apps" class="text-white/50 hover:text-white transition-colors mx-4">Directory</a>
      <a href="/privacy" class="text-white/50 hover:text-white transition-colors mx-4">Privacy</a>
      <a href="/terms" class="text-white/50 hover:text-white transition-colors mx-4">Terms</a>
    </div>
    <p>&copy; 2026 ListSignal — Shopify Store Intelligence</p>
  </div>
</footer>
